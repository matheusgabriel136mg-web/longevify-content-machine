# Meta Graph API — get these from https://developers.facebook.com/apps/<APP_ID>/settings/basic/
META_APP_ID=
META_APP_SECRET=

# Filled automatically by get_token.py:
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
IG_BUSINESS_ACCOUNT_ID=

# Hosting — pick ONE block:

# Cloudinary (recommended — 25GB free)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# AWS S3
# S3_BUCKET=
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ngrok (local file serve, fastest for testing)
# NGROK_AUTHTOKEN=
